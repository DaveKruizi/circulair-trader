# Anthropic API key
ANTHROPIC_API_KEY=your_key_here

# Minimum sell price filter (euros)
MIN_SELL_PRICE=15

# Minimum net margin (euros)
MIN_NET_MARGIN=8

# Vinted commission placeholder (update when known)
VINTED_COMMISSION_PCT=5

# Default shipping cost (euros)
SHIPPING_COST=5

# Max budget per item (euros)
MAX_BUY_PRICE=50

# Vinted session cookie (access_token_web) — kopieer uit browser DevTools na inloggen
# Verloopt na ~2 weken; vernieuwen via Application > Cookies > vinted.nl
VINTED_SESSION_COOKIE=

# Dashboard output directory
OUTPUT_DIR=output
